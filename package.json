{
  "name": "with-you",
  "author": "arshe",
  "description": "A convenient note app",
  "private": true,
  "version": "0.3.2",
  "type": "module",
  "main": "dist-electron/index.js",
  "scripts": {
    "build:preload": "node scripts/build-preload.mjs",
    "dev:renderer": "vite",
    "dev": "npm run build:preload && node scripts/dev.mjs",
    "build": "vue-tsc -b && vite build && npm run build:preload && electron-builder",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "test": "vitest",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.2.4",
    "@codemirror/theme-one-dark": "^6.1.2",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "github-markdown-css": "^5.5.0",
    "highlight.js": "^11.9.0",
    "lucide-vue-next": "^0.511.0",
    "markdown-it": "^14.0.0",
    "pinia": "^2.1.7",
    "tailwind-merge": "^3.3.0",
    "vue": "^3.4.15"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vscode/test-electron": "^2.3.9",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.0",
    "electron-winstaller": "^5.3.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "unplugin-vue-dev-locator": "^1.0.0",
    "vite": "^5.0.12",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^1.2.1",
    "vue-tsc": "^1.8.27"
  }
}
